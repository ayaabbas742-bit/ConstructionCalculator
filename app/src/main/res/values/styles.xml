<resources>

<!-- شكل كل عنصر (زر فيه صورة + نص) -->
<style name="itemStyle">
    <item name="android:layout_width">90dp</item>
    <item name="android:layout_height">match_parent</item>
    <item name="android:orientation">vertical</item>
    <item name="android:gravity">center</item>
    <item name="android:padding">6dp</item>
    <item name="android:background">?attr/selectableItemBackground</item>
</style>

<!-- شكل الصورة داخل العنصر -->
<style name="imgStyle">
    <item name="android:layout_width">50dp</item>
    <item name="android:layout_height">50dp</item>
    <item name="android:scaleType">centerInside</item>
    <item name="android:adjustViewBounds">true</item>
</style>

<!-- Theme -->
<style name="AppTheme" parent="Theme.MaterialComponents.Light.NoActionBar">
    <item name="android:statusBarColor">#0D2535</item>
    <item name="android:navigationBarColor">#0D2535</item>
</style>
    <style name="CircleImageView">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
    <style name="GeoTheme" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/green_primary</item>
        <item name="colorPrimaryDark">@color/green_dark</item>
        <item name="colorAccent">@color/green_light</item>
        <item name="android:windowBackground">@color/background</item>
    </style>
    <style name="GeoInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/green_light</item>
        <item name="hintTextColor">@color/green_primary</item>
        <item name="boxCornerRadiusTopStart">10dp</item>
        <item name="boxCornerRadiusTopEnd">10dp</item>
        <item name="boxCornerRadiusBottomStart">10dp</item>
        <item name="boxCornerRadiusBottomEnd">10dp</item>
    </style>
    <style name="GeoButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/green_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>
    <style name="SectionTitle">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/green_primary</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="ResultLabel">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>
    <style name="ResultValue">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="ResultHighlight">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/green_primary</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="TabText" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">11sp</item>
        <item name="textAllCaps">false</item>
    </style>
</resources>