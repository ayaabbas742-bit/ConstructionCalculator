<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#ADD5AE">

    <!-- 🔷 Top App Bar (Professional Engineering Style) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="78dp"
        android:background="#8CB68E"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:elevation="8dp">

        <!-- Back Button -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_circle_green"
            android:src="@drawable/ic_arrow_back"
            app:tint="#FFFFFF"/>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <!-- Title -->
        <LinearLayout
            android:orientation="vertical"
            android:gravity="end"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="GEOTECHNICAL SYSTEM"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="Engineering Dashboard"
                android:textColor="#7FA7C9"
                android:textSize="12sp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- 🔵 Tab Layout (Modern Engineering Style) -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#77A979"
        app:tabIndicatorColor="#89CA8B"
        app:tabIndicatorHeight="3dp"
        app:tabSelectedTextColor="#FFFFFF"
        app:tabTextColor="#090909"
        app:tabRippleColor="#787878"
        app:tabMode="scrollable"
        app:tabGravity="start"
        android:elevation="6dp"/>

    <!-- 📄 ViewPager2 -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#707071"/>

</LinearLayout>