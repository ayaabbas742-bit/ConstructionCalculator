<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF8FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- TITLE -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="18dp"
            app:cardElevation="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🧱 Tiles Calculator PRO"
                android:textSize="22sp"
                android:textStyle="bold"
                android:gravity="center"
                android:padding="16dp"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- IMAGE CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="15dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="12dp">

            <ImageView
                android:id="@+id/imgTiles"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/tile_ceramic"
                android:scaleType="centerCrop"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- TYPE -->
        <Spinner
            android:id="@+id/spTileType"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="12dp"/>

        <!-- FLOOR -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📏 Floor Size"
            android:textStyle="bold"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/etFloorL"
                android:hint="Length"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="50dp"/>

            <EditText
                android:id="@+id/etFloorW"
                android:hint="Width"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="50dp"/>
        </LinearLayout>

        <!-- TILE SIZE -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🧩 Tile Size (cm)"
            android:textStyle="bold"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/etTileL"
                android:hint="Length"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="50dp"/>

            <EditText
                android:id="@+id/etTileW"
                android:hint="Width"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="50dp"/>
        </LinearLayout>

        <!-- BUTTON -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCalcTiles"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="CALCULATE"
            android:textColor="#FFFFFF"
            app:cornerRadius="12dp"
            android:backgroundTint="#5A6266"/>

        <!-- RESULT CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="8dp">

            <TextView
                android:id="@+id/tvTilesResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Result"
                android:textSize="18sp"
                android:textStyle="bold"
                android:padding="16dp"/>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>