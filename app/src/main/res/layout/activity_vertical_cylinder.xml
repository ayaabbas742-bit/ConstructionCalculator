<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vertical Cylinder Tank"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="15dp"/>

        <!-- IMAGE -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="180dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            android:layout_marginBottom="15dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_vertical_cylinder"
                android:scaleType="centerInside"/>
        </androidx.cardview.widget.CardView>

        <!-- TYPE (FULL / PARTIAL) -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            android:layout_marginBottom="15dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="15dp">

                <TextView
                    android:text="Tank Type"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <RadioGroup
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <RadioButton
                        android:id="@+id/radioFull"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Full Tank"
                        android:checked="true"/>

                    <RadioButton
                        android:id="@+id/radioPartial"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Partial Tank"/>
                </RadioGroup>

                <!-- Fill Height -->
                <EditText
                    android:id="@+id/editFill"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Fill Height (m) - only partial"
                    android:inputType="numberDecimal"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- INPUTS -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp"
            android:layout_marginBottom="15dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="15dp">

                <TextView
                    android:text="Radius (m)"
                    android:textStyle="bold"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
                <EditText
                    android:id="@+id/editRadius"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:inputType="numberDecimal"
                    android:hint="Enter radius"/>

                <TextView
                    android:text="Height (m)"
                    android:textStyle="bold"
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <EditText
                    android:id="@+id/editHeight"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:inputType="numberDecimal"
                    android:hint="Enter height"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- BUTTON -->
        <Button
            android:id="@+id/btnCalculate"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="CALCULATE"
            android:textColor="@android:color/white"
            android:backgroundTint="#0D47A1"/>

        <!-- RESULT -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp">

            <TextView
                android:id="@+id/txtResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Results will appear here"
                android:textSize="15sp"
                android:padding="15dp"/>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>