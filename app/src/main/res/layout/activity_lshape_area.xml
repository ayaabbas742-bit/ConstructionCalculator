<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:text="L Shape Calculator"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginBottom="20dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/lshape"
                android:scaleType="centerInside"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#33D2B48C"/>
        </FrameLayout>

        <!-- BIG RECTANGLE -->
        <TextView
            android:text="Big Length"
            android:textSize="18sp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <EditText
            android:id="@+id/editBigLength"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/edit_text_background"
            android:inputType="numberDecimal"
            android:hint="enter big length"/>

        <TextView
            android:text="Big Width"
            android:textSize="18sp"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <EditText
            android:id="@+id/editBigWidth"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/edit_text_background"
            android:inputType="numberDecimal"
            android:hint="enter big width"/>

        <!-- CUT RECTANGLE -->
        <TextView
            android:text="Cut Length"
            android:textSize="18sp"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <EditText
            android:id="@+id/editCutLength"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/edit_text_background"
            android:inputType="numberDecimal"
            android:hint="enter cut length"/>

        <TextView
            android:text="Cut Width"
            android:textSize="18sp"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <EditText
            android:id="@+id/editCutWidth"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/edit_text_background"
            android:inputType="numberDecimal"
            android:hint="enetr cut width"/>

        <Button
            android:id="@+id/btnCalculate"
            android:layout_width="150dp"
            android:layout_height="48dp"
            android:text="Calculate"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="15dp"
            android:backgroundTint="#000000"
            android:textColor="@android:color/white"/>

        <TextView
            android:id="@+id/txtArea"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@drawable/edit_text_background"
            android:text="Area = "
            android:padding="10dp"
            android:textSize="18sp"/>
    </LinearLayout>
</ScrollView>