<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF8FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- TITLE -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Brick Calculator PRO"
            android:textSize="26sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#111827"
            android:padding="10dp"/>

        <!-- IMAGE (IMPORTANT FIX) -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="220dp"
            android:layout_height="180dp"
            android:layout_gravity="center"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="25dp"
            app:cardElevation="10dp"
            app:cardUseCompatPadding="true">

            <ImageView
                android:id="@+id/imgBrick"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/brick_standard"
                android:scaleType="centerCrop"/>

        </com.google.android.material.card.MaterialCardView>

        <!-- INPUT CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#D4F1F4">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- BRICK -->
                <TextView
                    android:text="نوع الطوب"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <Spinner
                    android:id="@+id/spinnerBrick"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_input"
                    android:padding="8dp"/>

                <!-- UNIT -->
                <TextView
                    android:text="الوحدة"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <Spinner
                    android:id="@+id/spinnerUnit"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_input"
                    android:padding="8dp"/>

                <!-- THICKNESS -->
                <TextView
                    android:text="Thickness (cm)"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <Spinner
                    android:id="@+id/spinnerThickness"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_input"
                    android:padding="8dp"/>

                <!-- LENGTH -->
                <TextView
                    android:text="الطول"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <EditText
                    android:id="@+id/etLength"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Enter length"
                    android:background="@drawable/bg_input"
                    android:padding="10dp"/>

                <!-- HEIGHT -->
                <TextView
                    android:text="الارتفاع"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <EditText
                    android:id="@+id/etHeight"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Enter height"
                    android:background="@drawable/bg_input"
                    android:padding="10dp"/>

                <!-- MORTAR -->
                <TextView
                    android:text="نسبة الملاط"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <Spinner
                    android:id="@+id/spinnerMortar"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_input"
                    android:padding="8dp"/>

                <!-- DOORS -->
                <TextView
                    android:text="Doors area (m²)"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"/>

                <EditText
                    android:id="@+id/etDoors"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Enter doors area"
                    android:background="@drawable/bg_input"
                    android:padding="10dp"/>

                <!-- WINDOWS -->
                <TextView
                    android:text="Windows area (m²)"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"/>

                <EditText
                    android:id="@+id/etWindows"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Enter windows area"
                    android:background="@drawable/bg_input"
                    android:padding="10dp"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- BUTTONS -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCalc"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="احسب"
            android:layout_marginTop="15dp"
            android:backgroundTint="#077F8E"
            android:textColor="#FFFFFF"/>


        <!-- RESULTS -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="10dp"
            app:cardBackgroundColor="#B2F2FAFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:text="results"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <TextView android:text="🧱bricks"
                    android:textSize="19sp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvBrick"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView android:text="🏗 cement"
                    android:textSize="19sp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvCement"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView android:text="🏖 الرمل"
                    android:textSize="19sp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvSand"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView android:text="📦area"
                    android:textSize="19sp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
                <TextView android:id="@+id/tvArea"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:text="Volume"
                    android:textSize="18sp"
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvVolume"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="Total Cost"
                    android:textSize="18sp"
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>