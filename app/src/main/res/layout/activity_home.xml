<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F2">

    <!-- ================= HEADER ================= -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="210dp">

        <!-- 📸 BACKGROUND -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/header_image" />

        <!-- 🌑 OVERLAY (polished) -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#3A000000" />

        <!-- CONTENT -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="18dp">

            <!-- ⚙️ SETTINGS -->
            <ImageView
                android:id="@+id/ic_settings"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:background="@drawable/bg_circle"
                android:padding="8dp"
                android:src="@drawable/ic_settings"
                app:tint="#FFFFFF" />

            <!-- 👷 TITLE -->
            <TextView
                android:id="@+id/title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hi, Engineer 👷"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold"
                android:layout_marginTop="38dp" />

            <!-- 👤 NAME -->
            <TextView
                android:id="@+id/engineer_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_below="@id/title"
                android:layout_marginTop="6dp" />

            <!-- 📄 DESCRIPTION -->
            <TextView
                android:id="@+id/description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Construction calculator for engineering projects"
                android:textColor="#E7E7E7"
                android:textSize="18sp"
                android:lineSpacingExtra="2dp"
                android:layout_below="@id/engineer_name"
                android:layout_marginTop="6dp" />

        </RelativeLayout>

    </FrameLayout>

    <!-- 🔹 SPACE BETWEEN HEADER & CARDS -->
    <View
        android:layout_width="match_parent"
        android:layout_height="14dp"/>

    <!-- ================= GRID ================= -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:clipToPadding="false"/>

</LinearLayout>