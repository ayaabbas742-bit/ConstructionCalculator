<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#F2F2F2">
    <!--  HEADER  -->
    <RelativeLayout android:layout_width="match_parent" android:layout_height="150dp" android:background="@drawable/header_bg" android:padding="16dp">
        <!--  Icons top-right  -->
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:orientation="horizontal">

            <ImageView android:id="@+id/ic_settings" android:layout_width="24dp" android:layout_height="24dp" android:scaleType="centerCrop" android:src="@drawable/ic_settings"/>
        </LinearLayout>
        <!--  Title  -->
        <TextView android:id="@+id/title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="آلة حاسبة للبناء" android:textColor="#FFFFFF" android:textSize="24sp" android:textStyle="bold" android:layout_marginTop="16dp"/>
        <!--  Description  -->
        <TextView android:id="@+id/description" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="الآلة الحاسبة للبناء التي تساعدك في التخطيط والميزانية وتنفيذ مشاريعك" android:textColor="#FFFFFF" android:textSize="14sp" android:layout_below="@id/title" android:layout_marginTop="8dp"/>
    </RelativeLayout>
    <!--  GRID  -->
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/recycler" android:layout_width="match_parent" android:layout_height="match_parent" android:padding="8dp"/>
</LinearLayout>