<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEEEEE">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- TOOLBAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#1A5276"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="8dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_media_previous"
                app:tint="#FFFFFF"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Page 1of1"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:gravity="center"/>

            <ImageView
                android:id="@+id/btnShare"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_share"
                app:tint="#FFFFFF"/>
        </LinearLayout>

        <!-- INVOICE CARD -->
        <LinearLayout android:id="@+id/invoiceCard" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#FFFFFF" android:layout_margin="16dp" android:orientation="vertical" android:padding="16dp" android:elevation="4dp">

            <!-- HEADER: Business + Invoice Number -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/imgLogo"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@android:drawable/ic_menu_myplaces"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:id="@+id/tvBusinessName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A1A"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvInvoiceNumberBig"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"/>
            </LinearLayout>

            <!-- CLIENT + INVOICE INFO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <!-- Client Info -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bill To"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textColor="#888"/>

                    <TextView
                        android:id="@+id/tvClientName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvClientPhone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="#555"/>

                    <TextView
                        android:id="@+id/tvClientEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="#555"/>

                    <TextView
                        android:id="@+id/tvClientAddress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="#555"/>
                </LinearLayout>

                <!-- Invoice Info -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:id="@+id/tvInvoiceNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="#555"/>

                    <TextView
                        android:id="@+id/tvCreatedDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="#555"/>

                    <TextView
                        android:id="@+id/tvDueDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="#555"/>
                </LinearLayout>
            </LinearLayout>

            <!-- TABLE HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:background="#6A1B9A"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="8dp">

                <TextView android:layout_width="0dp" android:layout_weight="2"
                    android:layout_height="wrap_content"
                    android:text="Item" android:textColor="#FFFFFF"
                    android:textStyle="bold" android:textSize="12sp"/>

                <TextView android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Qty" android:textColor="#FFFFFF"
                    android:textStyle="bold" android:textSize="12sp"
                    android:gravity="center"/>
                <TextView android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Price" android:textColor="#FFFFFF"
                android:textStyle="bold" android:textSize="12sp"
                android:gravity="center"/>

                <TextView android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Disc" android:textColor="#FFFFFF"
                    android:textStyle="bold" android:textSize="12sp"
                    android:gravity="center"/>

                <TextView android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Tax" android:textColor="#FFFFFF"
                    android:textStyle="bold" android:textSize="12sp"
                    android:gravity="center"/>

                <TextView android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Total" android:textColor="#FFFFFF"
                    android:textStyle="bold" android:textSize="12sp"
                    android:gravity="end"/>
            </LinearLayout>

            <!-- ITEMS - Dynamic -->
            <LinearLayout
                android:id="@+id/itemsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp"/>

            <!-- PAYMENT INFO + TOTALS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <!-- Payment Method -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Payment Info"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:textColor="#888"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvPayment"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="#333"/>
                </LinearLayout>

                <!-- Totals -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <!-- Subtotal -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp">

                        <TextView android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Subtotal" android:textSize="12sp"
                            android:textColor="#555"/>

                        <TextView android:id="@+id/tvSubtotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp" android:textColor="#333"/>
                    </LinearLayout>
                    <!-- Discount -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp">

                        <TextView android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Discount (0%)" android:textSize="12sp"
                            android:textColor="#555"/>

                        <TextView android:id="@+id/tvDiscountAmt"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp" android:textColor="#333"/>
                    </LinearLayout>

                    <!-- Tax -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp">

                        <TextView android:id="@+id/tvTaxLabel"
                            android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Tax (0%)" android:textSize="12sp"
                            android:textColor="#555"/>

                        <TextView android:id="@+id/tvTaxAmt"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp" android:textColor="#333"/>
                    </LinearLayout>

                    <!-- Shipping -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="4dp">

                        <TextView android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Shipping" android:textSize="12sp"
                            android:textColor="#555"/>

                        <TextView android:id="@+id/tvShippingAmt"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp" android:textColor="#333"/>
                    </LinearLayout>

                    <!-- Grand Total -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#6A1B9A"
                        android:padding="6dp">

                        <TextView android:layout_width="0dp" android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Grand Total"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:textSize="13sp"/>

                        <TextView android:id="@+id/tvGrandTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            android:textSize="13sp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
            <!-- SIGNATURE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvPaymentLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Payment Method"
                        android:textStyle="bold"
                        android:textSize="11sp"
                        android:textColor="#555"/>

                    <TextView
                        android:id="@+id/tvTerms"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TERMS AND CONDITIONS ARE APPLICABLE"
                        android:textSize="10sp"
                        android:textColor="#888"/>
                </LinearLayout>

                <ImageView
                    android:id="@+id/imgSignature"
                    android:layout_width="100dp"
                    android:layout_height="80dp"
                    android:visibility="gone"
                    android:scaleType="fitCenter"/>
            </LinearLayout>

            <!-- BUSINESS FOOTER -->
            <View android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <TextView
                    android:id="@+id/tvBusinessEmail"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="10sp"
                    android:textColor="#555"
                    android:gravity="center"/>

                <TextView
                    android:id="@+id/tvBusinessPhone"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="10sp"
                    android:textColor="#555"
                    android:gravity="center"/>

                <TextView
                    android:id="@+id/tvBusinessWebsite"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="10sp"
                    android:textColor="#555"
                    android:gravity="center"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvBusinessAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#555"
                android:gravity="center"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- SHARE BUTTONS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp">
            <Button
            android:id="@+id/btnShareBottom"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="Share"
            android:backgroundTint="#2196F3"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnWhatsApp"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="WhatsApp"
                android:backgroundTint="#25D366"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>