<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF8FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- TITLE -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Plaster Calculator PRO"
            android:textSize="26sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#111827"
            android:padding="10dp"/>

        <!-- IMAGE -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="220dp"
            android:layout_height="180dp"
            android:layout_gravity="center"
            app:cardCornerRadius="25dp"
            app:cardElevation="10dp">

            <ImageView
                android:id="@+id/imgPlaster"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/plaster"
                android:scaleType="centerCrop"/>
        </com.google.android.material.card.MaterialCardView>
        <!-- INPUT CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#D4F1F4">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- 🧱 WALL -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🧱 Wall Dimensions"
                    android:textStyle="bold"
                    android:textColor="#334155"
                    android:paddingTop="8dp"
                    android:paddingBottom="4dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/etLength"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:hint="Length (m)"
                        android:layout_height="50dp"/>

                    <EditText
                        android:id="@+id/etHeight"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:hint="Height (m)"
                        android:layout_height="50dp"/>
                </LinearLayout>

                ---

                <!-- 🚪 DOOR -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🚪 Door Dimensions"
                    android:textStyle="bold"
                    android:textColor="#334155"
                    android:paddingTop="10dp"
                    android:paddingBottom="4dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/etDoorL"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:hint="Length (m)"
                        android:layout_height="50dp"/>

                    <EditText
                        android:id="@+id/etDoorW"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:hint="Width (m)"
                        android:layout_height="50dp"/>
                </LinearLayout>

                ---

                <!-- 🪟 WINDOW -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🪟 Window Dimensions"
                    android:textStyle="bold"
                    android:textColor="#334155"
                    android:paddingTop="10dp"
                    android:paddingBottom="4dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/etWindowL"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:hint="Length (m)"
                        android:layout_height="50dp"/>

                    <EditText
                        android:id="@+id/etWindowW"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:hint="Width (m)"
                        android:layout_height="50dp"/>
                </LinearLayout>
                <!-- ADD -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddWall"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="ADD WALL"
                    android:backgroundTint="#455A64"/>
                <!-- DELETE -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDeleteWall"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="DELETE LAST WALL"
                    android:backgroundTint="#3D3E3E"/>

                <!-- RESET -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReset"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="RESET"
                    android:backgroundTint="#263238"/>

                <!-- WALLS -->
                <TextView
                    android:id="@+id/tvWalls"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Walls: none"
                    android:textSize="16sp"
                    android:padding="10dp"
                    android:textColor="#111827"/>

                <!-- THICKNESS -->
                <TextView
                    android:text="Thickness (mm)"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <Spinner
                    android:id="@+id/spinnerThickness"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"/>

                <!-- MORTAR -->
                <TextView
                    android:text="Mortar Ratio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

                <Spinner
                    android:id="@+id/spinnerMortar"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- CALCULATE -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCalcPlaster"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="CALCULATE"
            android:layout_marginTop="15dp"
            android:backgroundTint="#077F8E"/>

        <!-- RESULTS -->
        <TextView
            android:id="@+id/tvArea"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvVolume"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvCement"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvSand"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textStyle="bold"/>

    </LinearLayout>

</ScrollView>