<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#ECEFF1">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
        <!--  HEADER  -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#37474F" android:padding="20dp" android:layout_marginBottom="16dp">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="CONCRETE" android:textSize="32sp" android:textStyle="bold" android:textColor="#CFD8DC" android:letterSpacing="0.15" android:gravity="center"/>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="CALCULATOR PRO · 🇩🇿 Algerian Standard" android:textSize="12sp" android:textColor="#90A4AE" android:gravity="center" android:letterSpacing="0.1" android:layout_marginTop="4dp"/>
        </LinearLayout>
        <!--  SUBTITLE  -->
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="DTR BC 2.41 / CBA93 — Algeria" android:textSize="13sp" android:gravity="center" android:textColor="#6B7280" android:paddingBottom="8dp"/>
        <!--  IMAGE CARD  -->
        <com.google.android.material.card.MaterialCardView android:layout_width="220dp" android:layout_height="160dp" android:layout_gravity="center" android:layout_marginTop="8dp" android:layout_marginBottom="12dp" app:cardCornerRadius="20dp" app:cardElevation="10dp" app:strokeWidth="2dp" app:strokeColor="#CFD8DC">
            <ImageView android:id="@+id/imgElement" android:layout_width="match_parent" android:layout_height="match_parent" android:src="@drawable/slab" android:scaleType="centerCrop"/>
        </com.google.android.material.card.MaterialCardView>
        <!--  STRUCTURAL ELEMENT CARD  -->
        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" app:cardCornerRadius="12dp" app:cardElevation="6dp" app:cardBackgroundColor="#FAFAFA">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                    <View android:layout_width="4dp" android:layout_height="24dp" android:background="#CFD8DC" android:layout_marginEnd="10dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="STRUCTURAL ELEMENT" android:textSize="13sp" android:textStyle="bold" android:textColor="#37474F" android:letterSpacing="0.1"/>
                </LinearLayout>
                <Spinner android:id="@+id/spinnerElement" android:layout_width="match_parent" android:layout_height="50dp" android:background="@drawable/spinner_bg"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <!--  CONCRETE GRADE CARD  -->
        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" app:cardCornerRadius="12dp" app:cardElevation="6dp" app:cardBackgroundColor="#FAFAFA">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                    <View android:layout_width="4dp" android:layout_height="24dp" android:background="#CFD8DC" android:layout_marginEnd="10dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CONCRETE GRADE (fc28)" android:textSize="13sp" android:textStyle="bold" android:textColor="#37474F" android:letterSpacing="0.1"/>
                </LinearLayout>
                <Spinner android:id="@+id/spinnerGrade" android:layout_width="match_parent" android:layout_height="50dp" android:background="@drawable/spinner_bg"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    <!-- COST ESTIMATION CARD -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="#FAFAFA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <View
                android:layout_width="4dp"
                android:layout_height="24dp"
                android:background="#CFD8DC"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💰 COST ESTIMATION (optional)"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#F57F17"/>

        </LinearLayout>

        <!-- Cement Price -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="💰 Price per cement bag (DZD)"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#455A64"
            android:paddingBottom="4dp"/>

        <EditText
            android:id="@+id/etCementPrice"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="0.00 DZD"
            android:inputType="numberDecimal"
            android:background="@drawable/edittext_bg"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="10dp"/>

        <!-- Sand Price -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🪣 Price per m³ sand (DZD)"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#455A64"
            android:paddingBottom="4dp"/>

        <EditText
            android:id="@+id/etSandPrice"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="0.00 DZD"
            android:inputType="numberDecimal"
            android:background="@drawable/edittext_bg"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="10dp"/>

        <!-- Gravel Price -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🪨 Price per m³ gravel (DZD)"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#455A64"
            android:paddingBottom="4dp"/>

        <EditText
            android:id="@+id/etGravelPrice"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="0.00 DZD"
            android:inputType="numberDecimal"
            android:background="@drawable/edittext_bg"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="10dp"/>

        <!-- Steel Price -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚙️ Price per kg steel (DZD)"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#455A64"
            android:paddingBottom="4dp"/>
        <EditText
            android:id="@+id/etSteelPrice"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="0.00 DZD"
            android:inputType="numberDecimal"
            android:background="@drawable/edittext_bg"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ℹ️ All fields optional — fill only what you know"
            android:textSize="10sp"
            android:textColor="#8D6E63"
            android:layout_marginTop="8dp"/>

    </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
        <!--  DIMENSIONS CARD  -->
        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" app:cardCornerRadius="12dp" app:cardElevation="6dp" app:cardBackgroundColor="#FAFAFA">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                    <View android:layout_width="4dp" android:layout_height="24dp" android:background="#CFD8DC" android:layout_marginEnd="10dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DIMENSIONS" android:textSize="13sp" android:textStyle="bold" android:textColor="#37474F" android:letterSpacing="0.1"/>
                </LinearLayout>
                <EditText android:id="@+id/etLength" android:layout_width="match_parent" android:layout_height="50dp" android:hint="Length (m)" android:inputType="numberDecimal" android:background="@drawable/edittext_bg" android:paddingStart="12dp" android:paddingEnd="12dp" android:layout_marginBottom="8dp"/>
                <EditText android:id="@+id/etWidth" android:layout_width="match_parent" android:layout_height="50dp" android:hint="Width (m)" android:inputType="numberDecimal" android:background="@drawable/edittext_bg" android:paddingStart="12dp" android:paddingEnd="12dp" android:layout_marginBottom="8dp"/>
                <EditText android:id="@+id/etHeight" android:layout_width="match_parent" android:layout_height="50dp" android:hint="Thickness / Height (m)" android:inputType="numberDecimal" android:background="@drawable/edittext_bg" android:paddingStart="12dp" android:paddingEnd="12dp" android:layout_marginBottom="8dp"/>
                <EditText android:id="@+id/etOpenings" android:layout_width="match_parent" android:layout_height="50dp" android:hint="Openings / Voids (m³) — optional" android:inputType="numberDecimal" android:background="@drawable/edittext_bg" android:paddingStart="12dp" android:paddingEnd="12dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <!--  WASTE FACTOR CARD  -->
        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" app:cardCornerRadius="12dp" app:cardElevation="6dp" app:cardBackgroundColor="#FAFAFA">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                    <View android:layout_width="4dp" android:layout_height="24dp" android:background="#CFD8DC" android:layout_marginEnd="10dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="WASTE FACTOR: " android:textSize="13sp" android:textStyle="bold" android:textColor="#37474F"/>
                    <TextView android:id="@+id/tvWasteValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5%" android:textStyle="bold" android:textColor="#D32F2F"/>
                </LinearLayout>
                <SeekBar android:id="@+id/wasteBar" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="15" android:progress="5"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!--  BUTTONS  -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="3" android:layout_marginBottom="12dp">
            <com.google.android.material.button.MaterialButton android:id="@+id/btnCalc" android:layout_width="0dp" android:layout_weight="1" android:layout_height="56dp" android:layout_marginEnd="4dp" android:text="🧮 CALCULATE" android:textSize="12sp" android:textStyle="bold" android:textColor="#37474F" app:backgroundTint="#CFD8DC" app:cornerRadius="10dp"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btnHistory" android:layout_width="0dp" android:layout_weight="1" android:layout_height="56dp" android:layout_marginStart="4dp" android:layout_marginEnd="4dp" android:text="📋 HISTORY" android:textSize="12sp" app:backgroundTint="#455A64" app:cornerRadius="10dp"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btnShare" android:layout_width="0dp" android:layout_weight="1" android:layout_height="56dp" android:layout_marginStart="4dp" android:text="📤 SHARE" android:textSize="12sp" app:backgroundTint="#009688" app:cornerRadius="10dp"/>
        </LinearLayout>
        <!--  Reset Button  -->
        <com.google.android.material.button.MaterialButton android:id="@+id/btnReset" android:layout_width="match_parent" android:layout_height="50dp" android:layout_marginBottom="12dp" android:text="🔄 RESET" android:textSize="14sp" app:backgroundTint="#B71C1C" app:cornerRadius="10dp"/>
        <!--  RESULTS CARD  -->
        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp" app:cardCornerRadius="12dp" app:cardElevation="6dp" app:cardBackgroundColor="#37474F" app:strokeColor="#CFD8DC" app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="RESULTS" android:textSize="11sp" android:textStyle="bold" android:textColor="#CFD8DC" android:letterSpacing="0.15" android:layout_marginBottom="10dp"/>
                <TextView android:id="@+id/tvResult" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Result will appear here…" android:textSize="13sp" android:fontFamily="monospace" android:textColor="#ECEFF1" android:lineSpacingExtra="4dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>