<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Irregular Shape Calculator"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal"
            android:paddingBottom="10dp"/>

        <!-- CANVAS -->
        <com.example.constructioncalculator.IrregularShapeView
            android:id="@+id/shapeView"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="#EEE"
            android:layout_marginBottom="15dp"/>

        <!-- POINT COUNT -->
        <TextView
            android:id="@+id/tvPointCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Points added: 0"
            android:textSize="14sp"
            android:textColor="#666666"
            android:paddingBottom="8dp"/>

        <!-- INPUT -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add Point"
            android:textSize="15sp"
            android:textStyle="bold"
            android:paddingBottom="6dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/etX"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:hint="X"
                android:inputType="numberDecimal"
                android:layout_marginEnd="8dp"/>

            <EditText
                android:id="@+id/etY"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:hint="Y"
                android:inputType="numberDecimal"/>

        </LinearLayout>

        <!-- BUTTONS -->
        <Button
            android:id="@+id/btnAddPoint"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="➕ Add Point"
            android:backgroundTint="#2196F3"
            android:layout_marginTop="10dp"/>

        <Button
            android:id="@+id/btnDeletePoint"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="❌ Delete Last Point"
            android:backgroundTint="#5B5A5A"
            android:layout_marginTop="6dp"/>

        <Button
            android:id="@+id/btnClearPoints"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="♻️ Clear All"
            android:backgroundTint="#786969"
            android:layout_marginTop="6dp"/>

        <Button
            android:id="@+id/btnCalculate"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="📐 Calculate Area"
            android:backgroundTint="#3C3C3C"
            android:layout_marginTop="10dp"/>

        <!-- RESULT -->
        <TextView
            android:id="@+id/txtArea"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Area ="
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="16dp"
            android:layout_marginTop="10dp"
            android:background="#F5F5F5"/>

    </LinearLayout>
</ScrollView>