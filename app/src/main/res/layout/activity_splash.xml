<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#1FA7A5" android:gravity="center">
<LinearLayout android:orientation="vertical" android:gravity="center" android:layout_width="wrap_content" android:layout_height="wrap_content">
    <!--  صورة الرافعة  -->
    <ImageView android:id="@+id/logo" android:layout_width="350dp" android:layout_height="400dp" android:src="@drawable/crane" android:scaleType="centerInside" android:adjustViewBounds="true" android:layout_marginBottom="16dp"/>
    <!--  اسم التطبيق  -->
    <TextView android:id="@+id/app_name_splash" android:text="@string/app_name" android:textSize="28sp" android:textColor="#FFFFFF" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <!--  وصف قصير  -->
    <TextView android:id="@+id/app_desc_splash" android:text="Calculate. Plan. Build." android:textSize="18sp" android:textColor="#DDFFFFFF" android:layout_marginTop="8dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <!--  Loader نقاط  -->
    <LinearLayout android:orientation="horizontal" android:layout_marginTop="24dp" android:gravity="center" android:layout_width="wrap_content" android:layout_height="wrap_content">
        <View android:id="@+id/dot1" android:layout_width="10dp" android:layout_height="10dp" android:background="#FFFFFF" android:layout_margin="4dp"/>
        <View android:id="@+id/dot2" android:layout_width="10dp" android:layout_height="10dp" android:background="#FFFFFF" android:layout_margin="4dp"/>
        <View android:id="@+id/dot3" android:layout_width="10dp" android:layout_height="10dp" android:background="#FFFFFF" android:layout_margin="4dp"/>
    </LinearLayout>
</LinearLayout>
</RelativeLayout>