<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0E293C">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="230dp"
        android:src="@drawable/splash_bottom_wave"
        android:scaleType="fitXY"
        android:layout_alignParentBottom="true"/>


    <LinearLayout
        android:orientation="vertical"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- صورة الرافعة -->
        <ImageView
            android:id="@+id/logo"
            android:layout_width="400dp"
            android:layout_height="280dp"
            android:layout_marginBottom="16dp"
            android:adjustViewBounds="true"
            android:scaleType="centerInside"
            android:src="@drawable/crane1" />

        <!-- اسم التطبيق -->
        <TextView
            android:id="@+id/app_name_splash"
            android:text="@string/app_name"
            android:textSize="28sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- وصف قصير -->
        <TextView
            android:id="@+id/app_desc_splash"
            android:text="Calculate. Plan. Build."
            android:textSize="20sp"
            android:textColor="#1FA7A5"
            android:layout_marginTop="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- نقاط Loader -->
        <LinearLayout
            android:orientation="horizontal"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <View
                android:id="@+id/dot1"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:background="@drawable/dot_shape"
                android:layout_margin="4dp"/>

            <View
                android:id="@+id/dot2"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/dot_shape"
                android:layout_margin="4dp"/>

            <View
                android:id="@+id/dot3"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/dot_shape"
                android:layout_margin="4dp"/>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>