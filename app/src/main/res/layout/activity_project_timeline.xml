<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#F0F4F8">

    <androidx.core.widget.NestedScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:fillViewport="true">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
            <!-- Header -->
            <RelativeLayout android:id="@+id/headerSection" android:layout_width="match_parent" android:layout_height="280dp" android:background="@drawable/bg_header_gradient" android:padding="0dp">
                <!--  Background decoration circles  -->
                <View android:layout_width="220dp" android:layout_height="220dp" android:layout_alignParentRight="true" android:layout_marginTop="-60dp" android:layout_marginRight="-60dp" android:background="@drawable/circle_decoration_light"/>
                <View android:layout_width="120dp" android:layout_height="120dp" android:layout_marginLeft="20dp" android:layout_marginTop="160dp" android:background="@drawable/circle_decoration_dark"/>
                <!--  TOP BAR  -->
                <LinearLayout android:id="@+id/topBar" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="20dp" android:paddingEnd="20dp" android:paddingTop="40dp" android:paddingBottom="10dp">
                    <ImageButton android:id="@+id/btnBack" android:layout_width="40dp" android:layout_height="40dp" android:src="@drawable/ic_arrow_back_white" android:background="@drawable/btn_circle_semi" android:padding="8dp" android:contentDescription="Back"/>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Project Timeline" android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" android:fontFamily="sans-serif-medium" android:paddingStart="12dp"/>
                    <Button android:id="@+id/btnNewProject" android:layout_width="wrap_content" android:layout_height="36dp" android:text="+ New" android:textColor="#1B2A4A" android:textSize="13sp" android:textStyle="bold" android:background="@drawable/btn_gold_pill" android:paddingStart="16dp" android:paddingEnd="16dp"/>
                </LinearLayout>
                <!--  WEATHER CARD (floating inside header)  -->
                <androidx.cardview.widget.CardView android:id="@+id/weatherCard" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="20dp" android:layout_marginEnd="20dp" android:layout_marginTop="100dp" app:cardCornerRadius="24dp" app:cardElevation="16dp" app:cardBackgroundColor="@android:color/white">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_weather_card" android:padding="20dp">
                        <!--  Row 1: Icon + Temp + Info  -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                            <!--  Weather Icon BIG  -->
                            <TextView android:id="@+id/tvWeatherEmoji" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🌤️" android:textSize="52sp"/>
                            <!--  Temp + Desc  -->
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:paddingStart="16dp">
                                <TextView android:id="@+id/tvCity" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📍 Loading..." android:textColor="#C8E6FF" android:textSize="13sp"/>
                                <TextView android:id="@+id/tvTemperature" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--°C" android:textColor="#FFFFFF" android:textSize="40sp" android:textStyle="bold" android:fontFamily="sans-serif-light"/>
                                <TextView android:id="@+id/tvWeatherDesc" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Checking weather..." android:textColor="#C8E6FF" android:textSize="13sp"/>
                            </LinearLayout>
                            <!--  Humidity + Wind column  -->
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:background="@drawable/bg_stat_chip" android:paddingStart="10dp" android:paddingEnd="10dp" android:paddingTop="6dp" android:paddingBottom="6dp" android:layout_marginBottom="8dp">
                                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_humidity" android:layout_marginEnd="4dp"/>
                                    <TextView android:id="@+id/tvHumidity" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="--%" android:textColor="#A7ABC3" android:textSize="13sp" android:textStyle="bold"/>
                                </LinearLayout>
                                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:background="@drawable/bg_stat_chip" android:paddingStart="10dp" android:paddingEnd="10dp" android:paddingTop="6dp" android:paddingBottom="6dp">
                                    <ImageView android:layout_width="16dp" android:layout_height="16dp" android:src="@drawable/ic_wind" android:layout_marginEnd="4dp"/>
                                    <TextView android:id="@+id/tvWind" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-- km/h" android:textColor="#A9AECE" android:textSize="13sp" android:textStyle="bold"/>
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>
                        <!--  Construction advice strip  -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:background="@drawable/bg_advice_strip" android:paddingStart="12dp" android:paddingEnd="12dp" android:paddingTop="8dp" android:paddingBottom="8dp" android:layout_marginTop="12dp">
                            <ImageView android:layout_width="18dp" android:layout_height="18dp" android:src="@drawable/ic_construction_hat" android:layout_marginEnd="8dp"/>
                            <TextView android:id="@+id/tvWeatherAdvice" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Good conditions for outdoor construction" android:textColor="#FFD700" android:textSize="12sp" android:fontFamily="sans-serif-medium"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </RelativeLayout>

            <androidx.cardview.widget.CardView android:id="@+id/projectCard" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="20dp" android:layout_marginEnd="20dp" android:layout_marginTop="-20dp" android:layout_marginBottom="16dp" app:cardCornerRadius="24dp" app:cardElevation="12dp" app:cardBackgroundColor="#FFFFFF">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="24dp">
                    <!--  No project placeholder  -->
                    <LinearLayout android:id="@+id/layoutNoProject" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center" android:visibility="gone" android:padding="16dp">
                        <ImageView android:layout_width="80dp" android:layout_height="80dp" android:src="@drawable/ic_empty_project" android:alpha="0.5"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="No project yet!" android:textColor="#AAAAAA" android:textSize="16sp" android:textStyle="bold" android:layout_marginTop="12dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Tap '+ New' to create your first project" android:textColor="#BBBBBB" android:textSize="13sp" android:gravity="center"/>
                    </LinearLayout>
                    <!--  Project Info  -->
                    <LinearLayout android:id="@+id/layoutProjectInfo" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:visibility="visible">
                        <!--  Project name + status badge  -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                            <ImageView android:layout_width="36dp" android:layout_height="36dp" android:src="@drawable/ic_project_active" android:layout_marginEnd="12dp"/>
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                                <TextView android:id="@+id/tvProjectName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="My Project" android:textColor="#1B2A4A" android:textSize="18sp" android:textStyle="bold" android:fontFamily="sans-serif-medium"/>
                                <TextView android:id="@+id/tvProjectDates" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Jan 1 → Dec 31, 2025" android:textColor="#888888" android:textSize="12sp"/>
                            </LinearLayout>
                            <TextView android:id="@+id/tvStatusBadge" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🟢 Active" android:textColor="#FFFFFF" android:textSize="11sp" android:textStyle="bold" android:background="@drawable/bg_badge_green" android:paddingStart="12dp" android:paddingEnd="12dp" android:paddingTop="6dp" android:paddingBottom="6dp"/>
                        </LinearLayout>
                        <!--  Divider  -->
                        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" android:layout_marginTop="16dp" android:layout_marginBottom="16dp"/>
                        <!--  Stats Row  -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                            <!--  Days Left stat  -->
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="@drawable/bg_stat_orange" android:padding="12dp" android:layout_marginEnd="8dp">
                                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_calendar_orange"/>
                                <TextView
                                    android:id="@+id/tvDaysLeft"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="--"
                                    android:textColor="#E05C2A"
                                    android:textSize="22sp"
                                    android:textStyle="bold"/>
                                <TextView
                                    android:id="@+id/tvDaysLeftLabel"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Days Left"
                                    android:textColor="#E05C2A"
                                    android:textSize="11sp"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Days Left" android:textColor="#E05C2A" android:textSize="11sp"/>
                            </LinearLayout>
                            <!--  Phases stat  -->
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="@drawable/bg_stat_blue" android:padding="12dp" android:layout_marginEnd="8dp">
                                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_phases_blue"/>
                                <TextView android:id="@+id/tvTotalPhases" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#2E86AB" android:textSize="22sp" android:textStyle="bold"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Phases" android:textColor="#2E86AB" android:textSize="11sp"/>
                            </LinearLayout>
                            <!--  Done stat  -->
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:background="@drawable/bg_stat_green" android:padding="12dp">
                                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_check_green"/>
                                <TextView android:id="@+id/tvDonePhases" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textColor="#27AE60" android:textSize="22sp" android:textStyle="bold"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Done" android:textColor="#27AE60" android:textSize="11sp"/>
                            </LinearLayout>
                        </LinearLayout>
                        <!--  Progress Bar  -->
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Overall Progress" android:textColor="#888888" android:textSize="13sp" android:layout_marginTop="16dp" android:layout_marginBottom="8dp"/>
                        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical">
                            <ProgressBar android:id="@+id/progressBar" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="14dp" android:layout_toStartOf="@+id/tvProgressPercent" android:layout_marginEnd="12dp" android:max="100" android:progress="0" android:progressDrawable="@drawable/progress_bar_style" android:background="@drawable/progress_bg"/>
                            <TextView android:id="@+id/tvProgressPercent" android:layout_width="40dp" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:text="0%" android:textColor="#1B2A4A" android:textSize="14sp" android:textStyle="bold" android:gravity="end"/>
                        </RelativeLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:paddingStart="24dp" android:paddingEnd="24dp" android:paddingBottom="12dp">
                <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_phases_list" android:layout_marginEnd="8dp"/>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Project Phases" android:textColor="#1B2A4A" android:textSize="17sp" android:textStyle="bold" android:fontFamily="sans-serif-medium"/>
                <Button android:id="@+id/btnAddPhase" android:layout_width="wrap_content" android:layout_height="36dp" android:text="+ Phase" android:textColor="#FFFFFF" android:textSize="13sp" android:textStyle="bold" android:background="@drawable/btn_orange_pill" android:paddingStart="16dp" android:paddingEnd="16dp"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvPhases" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingStart="20dp" android:paddingEnd="20dp" android:paddingBottom="100dp" android:clipToPadding="false" android:nestedScrollingEnabled="false"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>