<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#F5F0EB">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
        <!--  ══════════════════════════════════════════════  -->
        <!--   HEADER  (same style as Bricks)                -->
        <!--  ══════════════════════════════════════════════  -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#2C1810" android:padding="20dp" android:layout_marginBottom="16dp">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="🪜 STAIR" android:textSize="32sp" android:textStyle="bold" android:textColor="#E8C97A" android:letterSpacing="0.15" android:gravity="center"/>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="CALCULATOR PRO · 🇩🇿 Algerian Standard DTR" android:textSize="12sp" android:textColor="#A08060" android:gravity="center" android:letterSpacing="0.1" android:layout_marginTop="4dp"/>
        </LinearLayout>
        <!--  ══════════════════════════════════════════════  -->
        <!--   STAIR TYPE CARD                               -->
        <!--  ══════════════════════════════════════════════  -->
        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" app:cardCornerRadius="12dp" app:cardElevation="6dp" app:cardBackgroundColor="#FFFDF8">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <!--  Section header  -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                    <View android:layout_width="4dp" android:layout_height="24dp" android:background="#E8C97A" android:layout_marginEnd="10dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="STAIR TYPE" android:textSize="13sp" android:textStyle="bold" android:textColor="#2C1810" android:letterSpacing="0.1"/>
                </LinearLayout>
                <!--  Stair preview image  -->
                <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="160dp" android:layout_gravity="center" android:layout_marginBottom="12dp" app:cardCornerRadius="10dp" app:cardElevation="4dp" app:strokeColor="#E8C97A" app:strokeWidth="2dp">
                    <ImageView android:id="@+id/imgStair" android:layout_width="match_parent" android:layout_height="match_parent" android:src="@drawable/straight" android:scaleType="centerCrop"/>
                </com.google.android.material.card.MaterialCardView>
                <!--  Type spinner  -->
                <Spinner android:id="@+id/spinnerType" android:layout_width="match_parent" android:layout_height="50dp" android:background="@drawable/spinner_bg" android:layout_marginBottom="10dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <!--  ══════════════════════════════════════════════  -->
        <!--   MAIN DIMENSIONS CARD                          -->
        <!--  ══════════════════════════════════════════════  -->
        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" app:cardCornerRadius="12dp" app:cardElevation="6dp" app:cardBackgroundColor="#FFFDF8">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <!--  Section header  -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                    <View android:layout_width="4dp" android:layout_height="24dp" android:background="#E8C97A" android:layout_marginEnd="10dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MAIN DIMENSIONS" android:textSize="13sp" android:textStyle="bold" android:textColor="#2C1810" android:letterSpacing="0.1"/>
                </LinearLayout>
                <!--  Total Height  -->
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="📏 Total Height H (m)" android:textSize="13sp" android:textStyle="bold" android:textColor="#5C3D2E" android:paddingBottom="4dp"/>
                <EditText android:id="@+id/etH" android:layout_width="match_parent" android:layout_height="50dp" android:hint="e.g. 2.80" android:inputType="numberDecimal" android:background="@drawable/edittext_bg" android:paddingStart="12dp" android:paddingEnd="12dp" android:layout_marginBottom="10dp"/>
                <!--  Width  -->
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="📐 Width W (m)" android:textSize="13sp" android:textStyle="bold" android:textColor="#5C3D2E" android:paddingBottom="4dp"/>
                <EditText android:id="@+id/etW" android:layout_width="match_parent" android:layout_height="50dp" android:hint="e.g. 1.20" android:inputType="numberDecimal" android:background="@drawable/edittext_bg" android:paddingStart="12dp" android:paddingEnd="12dp" android:layout_marginBottom="10dp"/>
                <!--  Available Length  -->
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="📏 Available Length (m)" android:textSize="13sp" android:textStyle="bold" android:textColor="#5C3D2E" android:paddingBottom="4dp"/>
                <EditText android:id="@+id/etL" android:layout_width="match_parent" android:layout_height="50dp" android:hint="e.g. 4.50" android:inputType="numberDecimal" android:background="@drawable/edittext_bg" android:paddingStart="12dp" android:paddingEnd="12dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <!--  ══════════════════════════════════════════════  -->
        <!--   SPIRAL PARAMETERS CARD (shown when spiral)    -->
        <!--  ══════════════════════════════════════════════  -->
        <com.google.android.material.card.MaterialCardView android:id="@+id/layoutSpiral" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:visibility="gone" app:cardCornerRadius="12dp" app:cardElevation="6dp" app:cardBackgroundColor="#FFFDF8">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <!--  Section header  -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                    <View android:layout_width="4dp" android:layout_height="24dp" android:background="#E8C97A" android:layout_marginEnd="10dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🌀 SPIRAL PARAMETERS" android:textSize="13sp" android:textStyle="bold" android:textColor="#2C1810" android:letterSpacing="0.1"/>
                </LinearLayout>
                <!--  External Diameter  -->
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="⭕ External Diameter D1 (m)" android:textSize="13sp" android:textStyle="bold" android:textColor="#5C3D2E" android:paddingBottom="4dp"/>
                <EditText android:id="@+id/etD1" android:layout_width="match_parent" android:layout_height="50dp" android:hint="e.g. 2.00" android:inputType="numberDecimal" android:background="@drawable/edittext_bg" android:paddingStart="12dp" android:paddingEnd="12dp" android:layout_marginBottom="10dp"/>
                <!--  Internal Diameter  -->
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="⭕ Internal Diameter D2 (m)" android:textSize="13sp" android:textStyle="bold" android:textColor="#5C3D2E" android:paddingBottom="4dp"/>
                <EditText android:id="@+id/etD2" android:layout_width="match_parent" android:layout_height="50dp" android:hint="e.g. 0.80" android:inputType="numberDecimal" android:background="@drawable/edittext_bg" android:paddingStart="12dp" android:paddingEnd="12dp" android:layout_marginBottom="10dp"/>
                <!--  Rotation Angle  -->
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="🔄 Rotation Angle α (degrees)" android:textSize="13sp" android:textStyle="bold" android:textColor="#5C3D2E" android:paddingBottom="4dp"/>
                <EditText android:id="@+id/etAlpha" android:layout_width="match_parent" android:layout_height="50dp" android:hint="e.g. 360" android:inputType="numberDecimal" android:background="@drawable/edittext_bg" android:paddingStart="12dp" android:paddingEnd="12dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <!--  ══════════════════════════════════════════════  -->
        <!--   COST ESTIMATION CARD  (same style as Bricks)  -->
        <!--  ══════════════════════════════════════════════  -->
        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" app:cardCornerRadius="12dp" app:cardElevation="6dp" app:cardBackgroundColor="#FFFDF8">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <!--  Section header  -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                    <View android:layout_width="4dp" android:layout_height="24dp" android:background="#E8C97A" android:layout_marginEnd="10dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💰 COST ESTIMATION (optional)" android:textSize="13sp" android:textStyle="bold" android:textColor="#F57F17" android:letterSpacing="0.1"/>
                </LinearLayout>
                <!--  Concrete Price  -->
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="🏗 Price per m³ concrete (DZD)" android:textSize="13sp" android:textStyle="bold" android:textColor="#5C3D2E" android:paddingBottom="4dp"/>
                <EditText android:id="@+id/etConcretePrice" android:layout_width="match_parent" android:layout_height="50dp" android:hint="0.00 DZD" android:inputType="numberDecimal" android:background="@drawable/edittext_bg" android:paddingStart="12dp" android:paddingEnd="12dp" android:layout_marginBottom="10dp"/>
                <!--  Finishing Price  -->
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="✨ Price per m² finishing (DZD)" android:textSize="13sp" android:textStyle="bold" android:textColor="#5C3D2E" android:paddingBottom="4dp"/>
                <EditText android:id="@+id/etFinishingPrice" android:layout_width="match_parent" android:layout_height="50dp" android:hint="0.00 DZD" android:inputType="numberDecimal" android:background="@drawable/edittext_bg" android:paddingStart="12dp" android:paddingEnd="12dp" android:layout_marginBottom="6dp"/>
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="ℹ️ Concrete: price per m³ of slab volume | Finishing: price per m² of stair area" android:textSize="10sp" android:textColor="#8D6E63"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
        <!--  ══════════════════════════════════════════════  -->
        <!--   ACTION BUTTONS                                -->
        <!--  ══════════════════════════════════════════════  -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="3" android:layout_marginBottom="12dp">
            <com.google.android.material.button.MaterialButton android:id="@+id/btnCalc" android:layout_width="0dp" android:layout_weight="1" android:layout_height="56dp" android:layout_marginEnd="6dp" android:text="📊 CALCULATE" android:textSize="12sp" android:textStyle="bold" android:textColor="#2C1810" app:backgroundTint="#E8C97A" app:cornerRadius="10dp"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btnHistory" android:layout_width="0dp" android:layout_weight="1" android:layout_height="56dp" android:layout_marginStart="6dp" android:text="📜 HISTORY" android:textSize="12sp" app:backgroundTint="#52400B" app:cornerRadius="10dp"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btnShare" android:layout_width="0dp" android:layout_weight="1" android:layout_height="56dp" android:layout_marginStart="6dp" android:text="📤 Share" android:textSize="12sp" android:backgroundTint="#009688" android:textColor="#FFFFFF" app:cornerRadius="10dp"/>
        </LinearLayout>
        <!--  Reset button full width  -->
        <com.google.android.material.button.MaterialButton android:id="@+id/btnReset" android:layout_width="match_parent" android:layout_height="50dp" android:layout_marginBottom="12dp" android:text="🔄 RESET" android:textSize="13sp" app:backgroundTint="#37474F" app:cornerRadius="10dp"/>
        <!--  ══════════════════════════════════════════════  -->
        <!--   RESULTS CARD  (same style as Bricks)          -->
        <!--  ══════════════════════════════════════════════  -->
        <com.google.android.material.card.MaterialCardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp" app:cardCornerRadius="12dp" app:cardElevation="6dp" app:cardBackgroundColor="#2C1810" app:strokeColor="#E8C97A" app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="RESULTS" android:textSize="11sp" android:textStyle="bold" android:textColor="#E8C97A" android:letterSpacing="0.15" android:layout_marginBottom="10dp"/>
                <TextView android:id="@+id/tvResult" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Engineering results will appear here..." android:textSize="13sp" android:fontFamily="monospace" android:textColor="#F5F0EB" android:lineSpacingExtra="4dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>
</ScrollView>