<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF8FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!--  HEADER                                  -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#CCE7EB" android:padding="20dp" android:layout_marginBottom="16dp">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="STAIR" android:textSize="32sp" android:textStyle="bold" android:textColor="#716F6B" android:letterSpacing="0.15" android:gravity="center"/>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="CALCULATOR PRO · 🇩🇿 Algerian Standard" android:textSize="12sp" android:textColor="#000000" android:gravity="center" android:letterSpacing="0.1" android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- IMAGE CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:layout_marginTop="15dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="12dp">

            <ImageView
                android:id="@+id/imgStair"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/straight"
                android:scaleType="centerCrop"/>
        </com.google.android.material.card.MaterialCardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            app:cardBackgroundColor="#DFF6F8"
            app:cardCornerRadius="12dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- TYPE -->
                <TextView
                    android:text="Type of Stair"
                    android:textStyle="bold"
                    android:layout_marginTop="10dp"
                    android:textColor="#333"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <Spinner
                    android:id="@+id/spinnerType"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="5dp"/>

                <!-- COMMON INPUTS -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Main Dimensions"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:layout_marginTop="12dp"
                    android:textColor="#222"/>

                <EditText
                    android:id="@+id/etH"
                    android:hint="Total Height H (m)"
                    android:inputType="numberDecimal"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"/>

                <EditText
                    android:id="@+id/etW"
                    android:hint="Width W (m)"
                    android:inputType="numberDecimal"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"/>

                <EditText
                    android:id="@+id/etL"
                    android:hint="Available Length (m)"
                    android:inputType="numberDecimal"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"/>

                <!-- 🌀 SPIRAL SECTION -->
                <LinearLayout
                    android:id="@+id/layoutSpiral"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="10dp">

                    <TextView
                        android:text="Spiral Stair Parameters"
                        android:textStyle="bold"
                        android:textColor="#444"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <EditText
                        android:id="@+id/etD1"
                        android:hint="External Diameter D1 (m)"
                        android:inputType="numberDecimal"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"/>

                    <EditText
                        android:id="@+id/etD2"
                        android:hint="Internal Diameter D2 (m)"
                        android:inputType="numberDecimal"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"/>

                    <EditText
                        android:id="@+id/etAlpha"
                        android:hint="Angle α (degrees)"
                        android:inputType="numberDecimal"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"/>
                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>
        <!-- BUTTONS -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2" android:layout_marginTop="14dp">
            <com.google.android.material.button.MaterialButton android:id="@+id/btnCalc" android:layout_width="0dp" android:layout_weight="1" android:layout_height="55dp" android:layout_marginEnd="5dp" android:text="📊 CALCULATE" app:backgroundTint="#5A5E5F"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btnHistory" android:layout_width="0dp" android:layout_weight="1" android:layout_height="55dp" android:layout_marginStart="5dp" android:text="📜 HISTORY" app:backgroundTint="#6A696B"/>
        </LinearLayout>
        <!-- RESULT -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp">

            <TextView
                android:id="@+id/tvResult"
                android:text="Engineering results will appear here..."
                android:textSize="16sp"
                android:padding="15dp"
                android:textColor="#000"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>