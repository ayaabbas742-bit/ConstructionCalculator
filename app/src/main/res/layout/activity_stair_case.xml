<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF8FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- TITLE -->
        <TextView
            android:text="Staircase Engineering PRO"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1E1E1E"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- IMAGE -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="6dp">

            <ImageView
                android:id="@+id/imgStair"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/straight"/>
        </androidx.cardview.widget.CardView>

        <!-- TYPE -->
        <TextView
            android:text="Type of Stair"
            android:textStyle="bold"
            android:layout_marginTop="10dp"
            android:textColor="#333"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <Spinner
            android:id="@+id/spinnerType"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="5dp"/>

        <!-- COMMON INPUTS -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="Main Dimensions"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginTop="12dp"
            android:textColor="#222"/>

        <EditText
            android:id="@+id/etH"
            android:hint="Total Height H (m)"
            android:inputType="numberDecimal"
            android:layout_width="match_parent"
            android:layout_height="50dp"/>

        <EditText
            android:id="@+id/etW"
            android:hint="Width W (m)"
            android:inputType="numberDecimal"
            android:layout_width="match_parent"
            android:layout_height="50dp"/>

        <EditText
            android:id="@+id/etL"
            android:hint="Available Length (m)"
            android:inputType="numberDecimal"
            android:layout_width="match_parent"
            android:layout_height="50dp"/>

        <!-- 🌀 SPIRAL SECTION (ENGINEERING ONLY) -->
        <LinearLayout
            android:id="@+id/layoutSpiral"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="10dp">

            <TextView
                android:text="Spiral Stair Parameters"
                android:textStyle="bold"
                android:textColor="#444"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/etD1"
                android:hint="External Diameter D1 (m)"
                android:inputType="numberDecimal"
                android:layout_width="match_parent"
                android:layout_height="50dp"/>
            <EditText
                android:id="@+id/etD2"
                android:hint="Internal Diameter D2 (m)"
                android:inputType="numberDecimal"
                android:layout_width="match_parent"
                android:layout_height="50dp"/>

            <EditText
                android:id="@+id/etAlpha"
                android:hint="Angle α (degrees)"
                android:inputType="numberDecimal"
                android:layout_width="match_parent"
                android:layout_height="50dp"/>
        </LinearLayout>

        <!-- BUTTONS -->
        <Button
            android:id="@+id/btnCalc"
            android:text="Calculate (Engineering Check)"
            android:textColor="#FFFFFF"
            android:backgroundTint="#303130"
            android:textStyle="bold"
            android:layout_marginTop="15dp"
            android:layout_width="match_parent"
            android:layout_height="55dp"/>

        <Button
            android:id="@+id/btnHistory"
            android:text="History"
            android:textColor="#FFFFFF"
            android:backgroundTint="#5B5B5B"
            android:textStyle="bold"
            android:layout_marginTop="10dp"
            android:layout_width="match_parent"
            android:layout_height="55dp"/>

        <!-- RESULT -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp">

            <TextView
                android:id="@+id/tvResult"
                android:text="Engineering results will appear here..."
                android:textSize="16sp"
                android:padding="15dp"
                android:textColor="#000"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>