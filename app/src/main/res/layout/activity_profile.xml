<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#F0F4F8" android:fillViewport="true">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
        <!--  ═══════════════════════════════════════  -->
        <!--  HEADER  (shorter + wave effect via padding)  -->
        <!--  ═══════════════════════════════════════  -->
        <FrameLayout android:layout_width="match_parent" android:layout_height="160dp" android:background="@drawable/header_gradient">
            <!--  back / settings row  -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingTop="16dp" android:layout_gravity="top">
                <ImageButton android:id="@+id/btnBack" android:layout_width="36dp" android:layout_height="36dp" android:background="@drawable/circle_white_alpha" android:src="@drawable/ic_arrow_back" app:tint="#FFFFFF" android:contentDescription="Back"/>
                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

            </LinearLayout>
            <!--  Title centered  -->
            <TextView android:text="Engineer Profile" android:textSize="22sp" android:textStyle="bold" android:textColor="#FFFFFF" android:letterSpacing="0.05" android:gravity="center" android:layout_gravity="center" android:layout_width="match_parent" android:layout_height="wrap_content"/>
        </FrameLayout>
        <!--  ═══════════════════════════════════════  -->
        <!--  PROFILE IMAGE  (overlaps header)  -->
        <!--  ═══════════════════════════════════════  -->
        <!-- PROFILE IMAGE -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-55dp"
            android:paddingBottom="8dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/profileImage"
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_engineer_avatar"
                android:scaleType="centerCrop"
                android:elevation="8dp"
                app:shapeAppearanceOverlay="@style/CircleImageView"
                app:strokeColor="#FFFFFF"
                app:strokeWidth="3dp"/>

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/cameraIcon"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center"
                android:layout_marginStart="70dp"
                android:layout_marginTop="70dp"
                android:background="#1FA7A5"
                android:padding="6dp"
                android:src="@drawable/ic_camera"
                android:tint="#FFFFFF"
                android:elevation="10dp"
                app:shapeAppearanceOverlay="@style/CircleImageView"/>

        </FrameLayout>
        <!--  Name display under photo  -->
        <TextView android:id="@+id/tvFullName" android:text="Manel Abbas" android:textSize="20sp" android:textStyle="bold" android:textColor="#1A1A2E" android:gravity="center" android:layout_width="match_parent" android:layout_height="wrap_content"/>
        <!--  Rating badge inline under name  -->
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:orientation="horizontal" android:background="@drawable/badge_teal_rounded" android:paddingStart="12dp" android:paddingEnd="12dp" android:paddingTop="4dp" android:paddingBottom="4dp" android:layout_marginTop="6dp" android:layout_marginBottom="20dp">
            <ImageView android:layout_width="14dp" android:layout_height="14dp" android:src="@drawable/ic_star_filled" app:tint="#FFD700"/>
            <TextView android:id="@+id/tvRatingBadge" android:text=" 4.5 · Certified Engineer" android:textSize="12sp" android:textColor="#FFFFFF" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
        <!--  ═══════════════════════════════════════  -->
        <!--  INFO CARD  -->
        <!--  ═══════════════════════════════════════  -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_marginEnd="16dp" android:layout_marginBottom="12dp" app:cardCornerRadius="20dp" app:cardElevation="3dp" app:cardBackgroundColor="#FFFFFF">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingStart="20dp" android:paddingEnd="20dp" android:paddingTop="20dp" android:paddingBottom="20dp">
                <!--  Section title  -->
                <TextView android:text="Personal Information" android:textSize="11sp" android:textColor="#1FA7A5" android:textStyle="bold" android:letterSpacing="0.12" android:layout_marginBottom="16dp" android:layout_width="match_parent" android:layout_height="wrap_content"/>
                <!--  First Name row  -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
                    <FrameLayout android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/icon_bg_teal_light">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:src="@drawable/ic_person" app:tint="#1FA7A5"/>
                    </FrameLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp">
                        <TextView android:text="First Name" android:textSize="11sp" android:textColor="#9E9E9E" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/tvFirstName" android:text="Manel" android:textSize="15sp" android:textColor="#1A1A2E" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" android:layout_marginBottom="16dp"/>
                <!--  Last Name row  -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="16dp">
                    <FrameLayout android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/icon_bg_teal_light">
                        <ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:src="@drawable/ic_person" app:tint="#1FA7A5"/>
                    </FrameLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp">
                        <TextView android:text="Last Name" android:textSize="11sp" android:textColor="#9E9E9E" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/tvLastName" android:text="Abbas" android:textSize="15sp" android:textColor="#1A1A2E" android:textStyle="bold" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" android:layout_marginBottom="16dp"/>
                <!--  Email row  -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                    <FrameLayout android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/icon_bg_teal_light">
                    <ImageView android:layout_width="20dp" android:layout_height="20dp" android:layout_gravity="center" android:src="@drawable/ic_email" />
                </FrameLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp">
                        <TextView android:text="Email" android:textSize="11sp" android:textColor="#9E9E9E" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/tvEmail" android:text="manelabbas387@gmail.com" android:textSize="14sp" android:textColor="#1A1A2E" android:textStyle="bold" android:ellipsize="end" android:maxLines="1" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
        <!--  ═══════════════════════════════════════  -->
        <!--  RATING CARD  (detailed)  -->
        <!--  ═══════════════════════════════════════  -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_marginEnd="16dp" android:layout_marginBottom="20dp" app:cardCornerRadius="20dp" app:cardElevation="3dp" app:cardBackgroundColor="#FFFFFF">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:paddingStart="20dp" android:paddingEnd="20dp" android:paddingTop="20dp" android:paddingBottom="20dp">
                <TextView android:text="Performance Rating" android:textSize="11sp" android:textColor="#1FA7A5" android:textStyle="bold" android:letterSpacing="0.12" android:layout_marginBottom="16dp" android:layout_width="match_parent" android:layout_height="wrap_content"/>
                <!--  Score + stars row  -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                    <!--  Big score  -->
                    <TextView android:id="@+id/tvScoreNumber" android:text="4.5" android:textSize="48sp" android:textStyle="bold" android:textColor="#1A1A2E" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">
                        <RatingBar android:id="@+id/ratingBar" style="@style/Widget.AppCompat.RatingBar.Small" android:numStars="5" android:stepSize="0.5" android:rating="4.5" android:isIndicator="true" android:progressTint="#1FA7A5" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/tvRatingLabel" android:text="Engineer Rating" android:textSize="13sp" android:textColor="#555" android:layout_marginTop="4dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/tvReviewCount" android:text="128 reviews" android:textSize="11sp" android:textColor="#9E9E9E" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
        <!--  ═══════════════════════════════════════  -->
        <!--  ACTION BUTTONS  -->
        <!--  ═══════════════════════════════════════  -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingStart="16dp" android:paddingEnd="16dp" android:layout_marginBottom="32dp">

            <!--  Logout  -->
            <com.google.android.material.button.MaterialButton android:id="@+id/logoutBtn" android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1" android:text="Logout" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" app:cornerRadius="14dp" app:backgroundTint="#E53935" android:layout_marginStart="8dp"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>