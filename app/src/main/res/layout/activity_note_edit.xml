<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:layoutDirection="rtl"
    android:background="#FFFFFF">

    <!-- Title Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#F8F8F8"
        android:paddingHorizontal="8dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#333333"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Construction Calculator"
            android:textSize="19sp"
            android:textStyle="bold"
            android:textColor="#1a1a1a"
            android:gravity="center"/>

        <ImageButton
            android:id="@+id/btnSaveTop"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_check"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#2196F3"/>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"/>

    <!-- Note Title -->
    <EditText
        android:id="@+id/etTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Note Title"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#1a1a1a"
        android:textColorHint="#BBBBBB"
        android:padding="16dp"
        android:gravity="end"
        android:background="@null"
        android:inputType="text"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        android:layout_marginHorizontal="16dp"/>

    <!-- Note Subtitle -->
    <EditText
        android:id="@+id/etSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Note Subtitle"
        android:textSize="18sp"
        android:textColor="#555555"
        android:textColorHint="#BBBBBB"
        android:padding="14dp"
        android:gravity="end"
        android:background="@null"
        android:inputType="text"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        android:layout_marginHorizontal="16dp"/>

    <!-- Note Body -->
    <EditText
        android:id="@+id/etBody"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:hint="Write a note here.."
        android:textSize="18sp"
        android:textColor="#333333"
        android:textColorHint="#BBBBBB"
        android:gravity="top|end"
        android:padding="16dp"
        android:background="@null"
        android:inputType="textMultiLine"/>

    <!-- Attach Panel -->
    <LinearLayout
        android:id="@+id/attachPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#F0F0F0"
        android:padding="16dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Attachments"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#333"
            android:gravity="end"
            android:layout_marginBottom="14dp"/>
        <!-- Color Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <View
                android:id="@+id/viewSelectedColor"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Note Color"
                android:textSize="13sp"
                android:textColor="#666"/>

            <View android:id="@+id/color1"
                android:layout_width="30dp" android:layout_height="30dp"
                android:layout_margin="3dp"/>
            <View android:id="@+id/color2"
                android:layout_width="30dp" android:layout_height="30dp"
                android:layout_margin="3dp"/>
            <View android:id="@+id/color3"
                android:layout_width="30dp" android:layout_height="30dp"
                android:layout_margin="3dp"/>
            <View android:id="@+id/color4"
                android:layout_width="30dp" android:layout_height="30dp"
                android:layout_margin="3dp"/>
            <View android:id="@+id/color5"
                android:layout_width="30dp" android:layout_height="30dp"
                android:layout_margin="3dp"/>
            <View android:id="@+id/color6"
                android:layout_width="30dp" android:layout_height="30dp"
                android:layout_margin="3dp"/>
        </LinearLayout>

        <!-- Icons Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="4dp">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginHorizontal="16dp">
                <ImageButton
                    android:id="@+id/btnShare"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:src="@drawable/ic_share"
                    android:background="@drawable/icon_circle_bg"
                    app:tint="#555555"
                    android:padding="14dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Share"
                    android:textSize="11sp"
                    android:textColor="#555"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginHorizontal="16dp">
                <ImageButton
                    android:id="@+id/btnAddFile"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:src="@drawable/ic_file"
                    android:background="@drawable/icon_circle_bg"
                    app:tint="#555555"
                    android:padding="14dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="File"
                    android:textSize="11sp"
                    android:textColor="#555"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginHorizontal="16dp">
                <ImageButton
                    android:id="@+id/btnAddLink"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:src="@drawable/ic_link"
                    android:background="@drawable/icon_circle_bg"
                    app:tint="#555555"
                    android:padding="14dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Link"
                    android:textSize="11sp"
                    android:textColor="#555"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginHorizontal="16dp">
                <ImageButton
                    android:id="@+id/btnAddImage"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:src="@drawable/ic_image"
                    android:background="@drawable/icon_circle_bg"
                    app:tint="#555555"
                    android:padding="14dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Image"
                    android:textSize="11sp"
                    android:textColor="#555"
                    android:layout_marginTop="6dp"/>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

    <!-- Bottom Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:padding="12dp"
        android:elevation="8dp">

        <Button
            android:id="@+id/btnSave"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Save"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:backgroundTint="#6D6D6D"
            android:layout_marginEnd="8dp"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/btnAttach"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Attach"
            android:textColor="#333333"
            android:textSize="15sp"
            android:backgroundTint="#EEEEEE"
            android:stateListAnimator="@null"/>

    </LinearLayout>

</LinearLayout>