<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:layoutDirection="rtl"
    android:background="#F5F5F5">

    <EditText
        android:id="@+id/etTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="عنوان الملاحظة"
        android:textSize="20sp"
        android:textStyle="bold"
        android:padding="16dp"
        android:gravity="end"
        android:background="@android:color/white"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"/>

    <EditText
        android:id="@+id/etSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="عنوان فرعي للملاحظة"
        android:textSize="15sp"
        android:padding="14dp"
        android:gravity="end"
        android:background="@android:color/white"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"/>

    <EditText
        android:id="@+id/etBody"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:hint="اكتب ملاحظة هنا.."
        android:gravity="top|end"
        android:padding="16dp"
        android:background="@android:color/white"/>

    <LinearLayout
        android:id="@+id/attachPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#EEEEEE"
        android:padding="16dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="إرفاق"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <View
                android:id="@+id/viewSelectedColor"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Note Color"
                android:textSize="14sp"/>

            <View android:id="@+id/color1"
                android:layout_width="28dp" android:layout_height="28dp"
                android:layout_margin="3dp"/>
            <View android:id="@+id/color2"
                android:layout_width="28dp" android:layout_height="28dp"
                android:layout_margin="3dp"/>
            <View android:id="@+id/color3"
                android:layout_width="28dp" android:layout_height="28dp"
                android:layout_margin="3dp"/>
            <View android:id="@+id/color4"
                android:layout_width="28dp" android:layout_height="28dp"
                android:layout_margin="3dp"/>
            <View android:id="@+id/color5"
                android:layout_width="28dp" android:layout_height="28dp"
                android:layout_margin="3dp"/>
            <View android:id="@+id/color6"
                android:layout_width="28dp" android:layout_height="28dp"
                android:layout_margin="3dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">
            <ImageButton
                android:id="@+id/btnAddImage"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_image"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_margin="8dp"/>

            <ImageButton
                android:id="@+id/btnAddLink"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_link"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_margin="8dp"/>

            <ImageButton
                android:id="@+id/btnAddFile"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_file"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_margin="8dp"/>

            <ImageButton
                android:id="@+id/btnShare"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_share"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_margin="8dp"/>
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@android:color/white"
        android:padding="8dp"
        android:elevation="4dp">

        <Button
            android:id="@+id/btnAttach"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="إرفاق"
            android:backgroundTint="#EEEEEE"
            android:textColor="#333333"
            android:layout_marginEnd="6dp"/>

        <Button
            android:id="@+id/btnSave"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="حفظ"
            android:backgroundTint="#2196F3"
            android:textColor="@android:color/white"/>
    </LinearLayout>

</LinearLayout>