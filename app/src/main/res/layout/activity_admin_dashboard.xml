<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:background="#060D1F" android:fillViewport="true">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
        <!--  ══════════════════════════════════════
                     HEADER — متدرج أزرق مع دوائر ضوئية
                     ══════════════════════════════════════  -->
        <FrameLayout android:layout_width="match_parent" android:layout_height="260dp">
            <!--  خلفية متدرجة  -->
            <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/admin_header_bg"/>
            <!--  دائرة ضوئية كبيرة يمين  -->
            <View android:layout_width="220dp" android:layout_height="220dp" android:layout_gravity="top|end" android:layout_marginTop="-80dp" android:layout_marginEnd="-80dp" android:background="@drawable/admin_glow_circle_large"/>
            <!--  دائرة ضوئية صغيرة يسار  -->
            <View android:layout_width="130dp" android:layout_height="130dp" android:layout_gravity="bottom|start" android:layout_marginStart="-40dp" android:layout_marginBottom="-40dp" android:background="@drawable/admin_glow_circle_small"/>
            <!--  نقاط زخرفية  -->
            <View android:layout_width="8dp" android:layout_height="8dp" android:layout_gravity="top|start" android:layout_marginStart="40dp" android:layout_marginTop="60dp" android:background="@drawable/admin_dot"/>
            <View android:layout_width="5dp" android:layout_height="5dp" android:layout_gravity="top|end" android:layout_marginEnd="80dp" android:layout_marginTop="120dp" android:background="@drawable/admin_dot"/>
            <!--  المحتوى  -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:gravity="center" android:paddingBottom="20dp">
                <!--  أيقونة Shield  -->
                <FrameLayout android:layout_width="88dp" android:layout_height="88dp">
                    <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/admin_avatar_ring"/>
                    <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:text="🛡️" android:textSize="38sp" android:gravity="center"/>
                </FrameLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ADMIN DASHBOARD" android:textSize="22sp" android:textStyle="bold" android:textColor="#FFFFFF" android:letterSpacing="0.15" android:layout_marginTop="12dp"/>
                <TextView android:id="@+id/tvWelcomeAdmin" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="مرحباً بك في لوحة التحكم" android:textSize="13sp" android:textColor="#90CAF9" android:layout_marginTop="4dp"/>
            </LinearLayout>
        </FrameLayout>
        <!--  ══════════════════════════════════════
                     بطاقات الإحصائيات — صف أفقي
                     ══════════════════════════════════════  -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingHorizontal="16dp" android:paddingTop="20dp" android:paddingBottom="4dp">
            <!--  بطاقة المستخدمين  -->
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="150dp" android:layout_weight="1" android:layout_marginEnd="8dp" app:cardCornerRadius="24dp" app:cardBackgroundColor="#0A1A3A" app:cardElevation="12dp">
                <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                    <!--  خط جانبي ملون  -->
                    <View android:layout_width="4dp" android:layout_height="match_parent" android:background="@drawable/admin_card_accent_blue"/>
                    <!--  بريق خلفي  -->
                    <View android:layout_width="80dp" android:layout_height="80dp" android:layout_gravity="bottom|end" android:layout_marginEnd="-20dp" android:layout_marginBottom="-20dp" android:background="@drawable/admin_glow_circle_small" android:alpha="0.3"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="16dp" android:gravity="center_horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="👥" android:textSize="28sp"/>
                    <TextView android:id="@+id/tvTotalUsers" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="34sp" android:textStyle="bold" android:textColor="#FFFFFF" android:layout_marginTop="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="المستخدمين" android:textSize="11sp" android:textColor="#5C9EE8" android:layout_marginTop="2dp"/>
                </LinearLayout>
                </FrameLayout>
            </androidx.cardview.widget.CardView>
            <!--  بطاقة التقييمات  -->
            <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="150dp" android:layout_weight="1" app:cardCornerRadius="24dp" app:cardBackgroundColor="#0A1A3A" app:cardElevation="12dp">
                <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">
                    <View android:layout_width="4dp" android:layout_height="match_parent" android:background="@drawable/admin_card_accent_cyan"/>
                    <View android:layout_width="80dp" android:layout_height="80dp" android:layout_gravity="bottom|end" android:layout_marginEnd="-20dp" android:layout_marginBottom="-20dp" android:background="@drawable/admin_glow_circle_cyan" android:alpha="0.3"/>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="16dp" android:gravity="center_horizontal">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💬" android:textSize="28sp"/>
                        <TextView android:id="@+id/tvTotalFeedback" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:textSize="34sp" android:textStyle="bold" android:textColor="#FFFFFF" android:layout_marginTop="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="التقييمات" android:textSize="11sp" android:textColor="#4DD0E1" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </FrameLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
        <!--  بطاقة متوسط التقييم — عرض كامل  -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginHorizontal="16dp" android:layout_marginTop="12dp" app:cardCornerRadius="24dp" app:cardBackgroundColor="#0A1A3A" app:cardElevation="12dp">
            <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                <!--  خلفية ذهبية خفية  -->
                <View android:layout_width="100dp" android:layout_height="100dp" android:layout_gravity="center|end" android:layout_marginEnd="-20dp" android:background="@drawable/admin_glow_circle_gold" android:alpha="0.2"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:padding="20dp" android:gravity="center_vertical">
                    <!--  أيقونة النجمة  -->
                    <FrameLayout android:layout_width="56dp" android:layout_height="56dp" android:background="@drawable/admin_icon_bg_gold">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="⭐" android:textSize="26sp"/>
                    </FrameLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Average Rating" android:textSize="12sp" android:textColor="#7B9CC8"/>
                        <TextView android:id="@+id/tvAvgRating" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.0 ⭐" android:textSize="26sp" android:textStyle="bold" android:textColor="#FFFFFF" android:layout_marginTop="2dp"/>
                        </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="/ 5" android:textSize="14sp" android:textColor="#3A5070"/>
                </LinearLayout>
            </FrameLayout>
        </androidx.cardview.widget.CardView>
        <!--  ══════════════════════════════════════
                     عنوان القسم
                     ══════════════════════════════════════  -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚡ الإجراءات" android:textSize="15sp" android:textStyle="bold" android:textColor="#FFFFFF" android:layout_marginHorizontal="20dp" android:layout_marginTop="24dp" android:layout_marginBottom="10dp"/>
        <!--  ══════════════════════════════════════
                     زر MANAGE USERS
                     ══════════════════════════════════════  -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginHorizontal="16dp" android:layout_marginBottom="10dp" app:cardCornerRadius="20dp" app:cardBackgroundColor="#0D1F45" app:cardElevation="8dp">
            <LinearLayout android:id="@+id/btnManageUsers" android:layout_width="match_parent" android:layout_height="70dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="20dp" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true">
                <FrameLayout android:layout_width="46dp" android:layout_height="46dp" android:background="@drawable/admin_btn_icon_blue">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="👥" android:textSize="22sp"/>
                </FrameLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Manage Users" android:textSize="15sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="عرض وحذف المستخدمين" android:textSize="11sp" android:textColor="#4A6FA8" android:layout_marginTop="2dp"/>
                </LinearLayout>
                <TextView android:layout_width="32dp" android:layout_height="32dp" android:text="›" android:textSize="26sp" android:textColor="#1E88E5" android:gravity="center"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
        <!--  ══════════════════════════════════════
                     زر VIEW FEEDBACK
                     ══════════════════════════════════════  -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginHorizontal="16dp" android:layout_marginBottom="10dp" app:cardCornerRadius="20dp" app:cardBackgroundColor="#0D1F45" app:cardElevation="8dp">
            <LinearLayout android:id="@+id/btnViewFeedback" android:layout_width="match_parent" android:layout_height="70dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="20dp" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true">
                <FrameLayout android:layout_width="46dp" android:layout_height="46dp" android:background="@drawable/admin_btn_icon_cyan">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="⭐" android:textSize="22sp"/>
                </FrameLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="14dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="View Feedback" android:textSize="15sp" android:textStyle="bold" android:textColor="#FFFFFF"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="آراء وتقييمات المستخدمين" android:textSize="11sp" android:textColor="#4A6FA8" android:layout_marginTop="2dp"/>
                </LinearLayout>
                <TextView android:layout_width="32dp" android:layout_height="32dp" android:text="›" android:textSize="26sp" android:textColor="#00BCD4" android:gravity="center"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
        <!--  ══════════════════════════════════════
                     فاصل
                     ══════════════════════════════════════  -->
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#0F1E3A" android:layout_marginHorizontal="16dp" android:layout_marginTop="10dp" android:layout_marginBottom="14dp"/>
        <!--  ══════════════════════════════════════
                     زر LOGOUT
                     ══════════════════════════════════════  -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginHorizontal="16dp" android:layout_marginBottom="36dp" app:cardCornerRadius="20dp" app:cardBackgroundColor="#1A0808" app:cardElevation="8dp">
            <LinearLayout android:id="@+id/btnLogout" android:layout_width="match_parent" android:layout_height="64dp" android:orientation="horizontal" android:gravity="center_vertical" android:paddingHorizontal="20dp" android:background="?attr/selectableItemBackground" android:clickable="true" android:focusable="true">
                <FrameLayout android:layout_width="46dp" android:layout_height="46dp" android:background="@drawable/admin_btn_icon_red">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:text="🚪" android:textSize="22sp"/>
                </FrameLayout>
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Logout" android:textSize="15sp" android:textStyle="bold" android:textColor="#EF5350" android:layout_marginStart="14dp"/>
                <TextView android:layout_width="32dp" android:layout_height="32dp" android:text="›" android:textSize="26sp" android:textColor="#EF5350" android:gravity="center"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>
