<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@android:color/white">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
        <!--  Title  -->
        <TextView android:id="@+id/txtTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Trapezoid Calculator" android:textSize="26sp" android:textStyle="bold" android:layout_gravity="center_horizontal" android:layout_marginBottom="20dp"/>
        <!--  Image + Overlay  -->
        <FrameLayout android:layout_width="match_parent" android:layout_height="220dp" android:layout_marginBottom="20dp">
            <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:src="@drawable/trapezoid" android:scaleType="centerInside"/>
            <View android:layout_width="match_parent" android:layout_height="match_parent" android:background="#33D2B48C"/>
            <!--  overlay ترابي  -->
        </FrameLayout>
        <!--  Base1  -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Base 1" android:textSize="18sp" android:layout_marginBottom="5dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
            <EditText android:id="@+id/editBase1" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:hint="Enter base 1" android:inputType="numberDecimal" android:background="@drawable/edit_text_background" android:padding="10dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="m" android:textSize="18sp" android:paddingStart="10dp"/>
        </LinearLayout>
        <!--  Base2  -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Base 2" android:textSize="18sp" android:layout_marginTop="10dp" android:layout_marginBottom="5dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
            <EditText android:id="@+id/editBase2" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:hint="Enter base 2" android:inputType="numberDecimal" android:background="@drawable/edit_text_background" android:padding="10dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="m" android:textSize="18sp" android:paddingStart="10dp"/>
        </LinearLayout>
        <!--  Height  -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Height" android:textSize="18sp" android:layout_marginTop="10dp" android:layout_marginBottom="5dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
            <EditText android:id="@+id/editHeight" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:hint="Enter height" android:inputType="numberDecimal" android:background="@drawable/edit_text_background" android:padding="10dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="m" android:textSize="18sp" android:paddingStart="10dp"/>
        </LinearLayout>
        <!--  Optional: Side1  -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Side 1 (optional)" android:textSize="18sp" android:layout_marginTop="10dp" android:layout_marginBottom="5dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
            <EditText android:id="@+id/editSide1" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:hint="Enter side 1" android:inputType="numberDecimal" android:background="@drawable/edit_text_background" android:padding="10dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="m" android:textSize="18sp" android:paddingStart="10dp"/>
        </LinearLayout>
        <!--  Optional: Side2  -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Side 2 (optional)" android:textSize="18sp" android:layout_marginTop="10dp" android:layout_marginBottom="5dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
            <EditText android:id="@+id/editSide2" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:hint="Enter side 2" android:inputType="numberDecimal" android:background="@drawable/edit_text_background" android:padding="10dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="m" android:textSize="18sp" android:paddingStart="10dp"/>
        </LinearLayout>
        <!--  Calculate Button  -->
        <Button android:id="@+id/btnCalculate" android:layout_width="150dp" android:layout_height="48dp" android:text="Calculate" android:layout_gravity="center_horizontal" android:layout_marginTop="15dp" android:backgroundTint="#000000" android:textColor="@android:color/white"/>
        <!--  Black separator  -->
        <View android:layout_width="match_parent" android:layout_height="2dp" android:background="@android:color/black" android:layout_marginTop="15dp" android:layout_marginBottom="15dp"/>
        <!--  Results  -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center_horizontal">
            <TextView android:id="@+id/txtArea" android:layout_width="match_parent" android:layout_height="60dp" android:background="@drawable/edit_text_background" android:padding="10dp" android:text="Area = " android:textSize="18sp" android:layout_marginBottom="10dp"/>
            <TextView android:id="@+id/txtPerimeter" android:layout_width="match_parent" android:layout_height="60dp" android:background="@drawable/edit_text_background" android:padding="10dp" android:text="Perimeter = " android:textSize="18sp"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>